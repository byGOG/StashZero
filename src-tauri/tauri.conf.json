{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "StashZero",
  "version": "0.3.2",
  "identifier": "com.stashzero.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StashZero",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "maximized": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-background-timer-throttling --disable-renderer-backgrounding --disable-backgrounding-occluded-windows"
      }
    ],
    "security": {
      "csp": {
        "default-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost"
        ],
        "script-src": [
          "'self'",
          "https://w.soundcloud.com"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ],
        "img-src": [
          "'self'",
          "data:",
          "blob:",
          "https:",
          "asset:",
          "http://asset.localhost",
          "ipc:"
        ],
        "frame-src": [
          "https://w.soundcloud.com"
        ],
        "connect-src": [
          "'self'",
          "https://api-v2.soundcloud.com",
          "https://*.sndcdn.com",
          "ipc:",
          "http://ipc.localhost"
        ],
        "font-src": [
          "'self'",
          "data:"
        ],
        "media-src": [
          "'self'",
          "blob:"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
